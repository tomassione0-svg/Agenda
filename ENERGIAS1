<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Proyecto de Energías Renovables</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root {
    --verde:       #1B6B2F;
    --verde-mid:   #2D8A45;
    --verde-light: #EAF5EC;
    --verde-badge: #D6EEDD;
    --teal:        #0D9E8C;
    --teal-light:  #E6F9F5;
    --azul:        #185FA5;
    --azul-light:  #EAF3FB;
    --amber:       #c07a00;
    --amber-light: #FFF3CD;
    --rojo:        #991f1f;
    --rojo-light:  #FDECEA;
    --gris:        #f4f4f4;
    --gris-borde:  #e0e0e0;
    --texto:       #1a1a1a;
    --muted:       #666;
    --bg:          #f8f9fa;
    --card-bg:     #ffffff;
    --shadow:      0 1px 4px rgba(0,0,0,0.08);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, 'Segoe UI', Arial, sans-serif; background: var(--bg); color: var(--texto); min-height: 100vh; }

  /* ── Header ── */
  .header { background: var(--verde); color: #fff; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .header h1 { font-size: 18px; font-weight: 600; letter-spacing: -0.3px; }
  .header-sub { font-size: 12px; opacity: 0.75; margin-top: 2px; }
  .sync-badge { font-size: 11px; background: rgba(255,255,255,0.15); padding: 4px 10px; border-radius: 20px; white-space: nowrap; display: flex; align-items: center; gap: 5px; }
  .sync-dot { width: 7px; height: 7px; border-radius: 50%; background: #4ade80; }
  .sync-dot.offline { background: #f87171; }
  .sync-dot.loading { background: #fbbf24; animation: pulse 1s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

  /* ── Nav tabs ── */
  .tabs { display: flex; background: #fff; border-bottom: 1px solid var(--gris-borde); padding: 0 16px; overflow-x: auto; }
  .tab { padding: 12px 16px; font-size: 13px; font-weight: 500; color: var(--muted); cursor: pointer; border-bottom: 2px solid transparent; white-space: nowrap; transition: color .15s, border-color .15s; }
  .tab.active { color: var(--verde); border-bottom-color: var(--verde); }
  .tab:hover { color: var(--verde); }

  /* ── Main layout ── */
  .main { max-width: 960px; margin: 0 auto; padding: 20px 16px; }
  .page { display: none; }
  .page.active { display: block; }

  /* ── Progress bars ── */
  .progress-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
  .progress-card { background: var(--card-bg); border: 1px solid var(--gris-borde); border-radius: 10px; padding: 14px 16px; }
  .progress-label { font-size: 12px; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
  .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .dot-verde { background: var(--verde); }
  .dot-azul { background: var(--azul); }
  .bar-wrap { background: var(--gris); border-radius: 4px; height: 6px; margin-bottom: 4px; }
  .bar { height: 6px; border-radius: 4px; transition: width .4s ease; }
  .bar-verde { background: var(--verde); }
  .bar-azul { background: var(--azul); }
  .bar-pct { font-size: 11px; color: var(--muted); text-align: right; }

  /* ── Section labels ── */
  .section-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); padding: 16px 0 6px; border-bottom: 1px solid var(--gris-borde); margin-bottom: 8px; }

  /* ── Task cards ── */
  .tasks { display: flex; flex-direction: column; gap: 6px; margin-bottom: 4px; }
  .task-card { background: var(--card-bg); border: 1px solid var(--gris-borde); border-radius: 8px; padding: 12px 14px; display: flex; align-items: flex-start; gap: 12px; cursor: pointer; transition: border-color .15s, box-shadow .15s; }
  .task-card:hover { border-color: #bbb; box-shadow: var(--shadow); }
  .task-card.done { opacity: 0.55; }
  .task-card.done .task-title { text-decoration: line-through; color: var(--muted); }
  .check-box { width: 20px; height: 20px; border-radius: 5px; border: 1.5px solid var(--gris-borde); flex-shrink: 0; margin-top: 1px; display: flex; align-items: center; justify-content: center; transition: background .15s, border-color .15s; }
  .check-box.checked-verde { background: var(--verde); border-color: var(--verde); }
  .check-box.checked-azul { background: var(--azul); border-color: var(--azul); }
  .check-icon { display: none; color: #fff; font-size: 12px; font-weight: 700; }
  .check-box.checked-verde .check-icon,
  .check-box.checked-azul .check-icon { display: block; }
  .task-body { flex: 1; min-width: 0; }
  .task-title { font-size: 14px; font-weight: 500; line-height: 1.4; }
  .task-sub { font-size: 12px; color: var(--muted); margin-top: 3px; line-height: 1.4; }
  .task-badges { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 6px; }
  .badge { font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 4px; }
  .badge-hecho   { background: var(--verde-badge); color: var(--verde); }
  .badge-curso   { background: var(--teal-light);  color: var(--teal); }
  .badge-pend    { background: var(--gris);        color: var(--muted); }
  .badge-urgente { background: var(--rojo-light);  color: var(--rojo); }
  .badge-alta    { background: var(--rojo-light);  color: var(--rojo); }
  .badge-media   { background: var(--amber-light); color: var(--amber); }
  .badge-baja    { background: var(--verde-badge); color: var(--verde); }

  /* ── Add task ── */
  .add-btn { display: flex; align-items: center; gap: 6px; background: none; border: 1.5px dashed var(--gris-borde); border-radius: 8px; padding: 10px 14px; width: 100%; cursor: pointer; color: var(--muted); font-size: 13px; transition: border-color .15s, color .15s; margin-top: 6px; }
  .add-btn:hover { border-color: var(--verde); color: var(--verde); }

  /* ── Modal ── */
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 100; display: none; align-items: center; justify-content: center; padding: 16px; }
  .modal-overlay.open { display: flex !important; }
  .modal { background: #fff; border-radius: 12px; padding: 24px; width: 100%; max-width: 440px; box-shadow: 0 8px 32px rgba(0,0,0,0.2); }
  .modal h2 { font-size: 16px; font-weight: 600; margin-bottom: 16px; }
  .modal label { display: block; font-size: 12px; font-weight: 600; color: var(--muted); margin-bottom: 4px; text-transform: uppercase; letter-spacing: .04em; }
  .modal input, .modal select, .modal textarea { width: 100%; border: 1px solid var(--gris-borde); border-radius: 6px; padding: 9px 11px; font-size: 14px; margin-bottom: 12px; font-family: inherit; }
  .modal textarea { height: 72px; resize: vertical; }
  .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 4px; }
  .btn { padding: 9px 18px; border-radius: 6px; font-size: 14px; font-weight: 500; cursor: pointer; border: none; transition: opacity .15s; }
  .btn-primary { background: var(--verde); color: #fff; }
  .btn-primary:hover { opacity: .88; }
  .btn-secondary { background: var(--gris); color: var(--texto); }
  .btn-delete { background: var(--rojo-light); color: var(--rojo); }

  /* ── Providers page ── */
  .prov-grid { display: flex; flex-direction: column; gap: 10px; }
  .prov-card { background: var(--card-bg); border: 1px solid var(--gris-borde); border-radius: 10px; padding: 16px; }
  .prov-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; margin-bottom: 8px; }
  .prov-name { font-size: 15px; font-weight: 600; }
  .prov-web { font-size: 12px; color: var(--teal); margin-top: 1px; }
  .prov-status { font-size: 11px; }
  .prov-rows { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 12px; }
  .prov-row { font-size: 12px; color: var(--muted); line-height: 1.5; }
  .prov-row strong { color: var(--texto); font-weight: 500; }
  .prio-pill { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; }
  .prio-alta   { background: var(--rojo-light);  color: var(--rojo); }
  .prio-media  { background: var(--amber-light); color: var(--amber); }
  .prio-baja   { background: var(--verde-badge); color: var(--verde); }

  /* ── Dimensionamiento page ── */
  .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .calc-card { background: var(--card-bg); border: 1px solid var(--gris-borde); border-radius: 10px; padding: 16px; }
  .calc-card h3 { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); margin-bottom: 14px; padding-bottom: 8px; border-bottom: 1px solid var(--gris-borde); }
  .calc-field { margin-bottom: 12px; }
  .calc-field label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 3px; }
  .calc-field input, .calc-field select { width: 100%; border: 1px solid var(--gris-borde); border-radius: 6px; padding: 8px 10px; font-size: 14px; font-family: inherit; }
  .calc-field input:focus, .calc-field select:focus { outline: none; border-color: var(--teal); }
  .result-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 14px; }
  .result-box { background: var(--verde-light); border: 1px solid var(--verde-badge); border-radius: 8px; padding: 12px; }
  .result-box.accent { background: var(--teal-light); border-color: #b2e8e0; }
  .result-val { font-size: 22px; font-weight: 700; color: var(--verde); line-height: 1; }
  .result-box.accent .result-val { color: var(--teal); }
  .result-label { font-size: 11px; color: var(--muted); margin-top: 4px; }
  .result-note { font-size: 10px; color: var(--muted); margin-top: 2px; font-style: italic; }

  /* ── Clientes page ── */
  .cliente-list { display: flex; flex-direction: column; gap: 8px; }
  .cliente-card { background: var(--card-bg); border: 1px solid var(--gris-borde); border-radius: 10px; padding: 14px 16px; display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
  .cliente-name { font-size: 14px; font-weight: 600; }
  .cliente-meta { font-size: 12px; color: var(--muted); margin-top: 3px; }
  .cliente-status-pill { font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 12px; white-space: nowrap; flex-shrink: 0; }
  .status-consulta  { background: var(--azul-light);   color: var(--azul); }
  .status-cotizando { background: var(--amber-light);  color: var(--amber); }
  .status-enviado   { background: var(--teal-light);   color: var(--teal); }
  .status-cerrado   { background: var(--verde-badge);  color: var(--verde); }
  .status-perdido   { background: var(--rojo-light);   color: var(--rojo); }
  .edit-btn { background: none; border: none; cursor: pointer; color: var(--muted); font-size: 16px; padding: 2px 4px; }
  .edit-btn:hover { color: var(--verde); }

  /* ── Empty state ── */
  .empty { text-align: center; padding: 40px 20px; color: var(--muted); font-size: 14px; }

  /* ── Toast ── */
  .toast { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: #222; color: #fff; padding: 10px 20px; border-radius: 8px; font-size: 13px; z-index: 200; opacity: 0; transition: opacity .3s; pointer-events: none; }
  .toast.show { opacity: 1; }

  @media (max-width: 600px) {
    .progress-row { grid-template-columns: 1fr; }
    .calc-grid { grid-template-columns: 1fr; }
    .result-grid { grid-template-columns: 1fr 1fr; }
    .prov-rows { grid-template-columns: 1fr; }
    .header h1 { font-size: 15px; }
  }
</style>
</head>
