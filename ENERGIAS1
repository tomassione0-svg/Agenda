          <div style="margin-top:16px;background:var(--gris);border-radius:8px;padding:12px">
            <div style="font-size:12px;font-weight:600;color:var(--muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:.04em">Resumen técnico</div>
            <div style="font-size:13px;line-height:1.8" id="r-resumen">—</div>
          </div>
          <button class="btn btn-primary" style="width:100%;margin-top:14px" onclick="guardarDim()">Guardar presupuesto</button>
        </div>
      </div>
      <div style="height:16px"></div>
      <div class="section-label">Presupuestos guardados — Térmica</div>
      <div id="dim-lista"></div>
    </div>

    <!-- ── FOTOVOLTAICO ── -->
    <div id="dim-fv" style="display:none">
      <div class="calc-grid">
        <div class="calc-card">
          <h3>Datos del proyecto</h3>
          <div class="calc-field"><label>Cliente / Proyecto</label>
            <input type="text" id="fv-cliente" placeholder="Nombre del cliente"></div>
          <div class="calc-field"><label>Consumo mensual (kWh/mes)</label>
            <input type="number" id="fv-consumo" value="300" min="50" oninput="calcularFV()">
            <span style="font-size:11px;color:var(--muted)">Dato de la factura de luz</span></div>
          <div class="calc-field"><label>% de consumo a cubrir</label>
            <select id="fv-cobertura" onchange="calcularFV()">
              <option value="0.75">75% — residencial típico</option>
              <option value="1.00" selected>100% — autoconsumo total</option>
              <option value="0.50">50% — reducción parcial</option>
            </select></div>
          <div class="calc-field"><label>Zona / HSP (horas solares pico)</label>
            <select id="fv-zona" onchange="calcularFV()">
              <option value="4.2">Buenos Aires / AMBA — 4.2 HSP</option>
              <option value="4.5">Córdoba / Santa Fe — 4.5 HSP</option>
              <option value="5.2">Mendoza / San Juan — 5.2 HSP</option>
              <option value="5.8">NOA (Salta, Jujuy, La Rioja) — 5.8 HSP</option>
              <option value="3.5">Patagonia — 3.5 HSP</option>
              <option value="4.0">Entre Ríos / Rosario — 4.0 HSP</option>
            </select></div>
          <div class="calc-field"><label>Potencia del panel (W)</label>
            <select id="fv-panel" onchange="calcularFV()">
              <option value="400">400 W — estándar residencial</option>
              <option value="430" selected>430 W — N-Type TOPCon (GPSOLAR)</option>
              <option value="550">550 W — comercial</option>
              <option value="600">600 W — industrial</option>
            </select></div>
          <div class="calc-field"><label>Performance Ratio (PR)</label>
            <select id="fv-pr" onchange="calcularFV()">
              <option value="0.75">0.75 — instalación básica</option>
              <option value="0.80" selected>0.80 — instalación estándar</option>
              <option value="0.85">0.85 — instalación óptima</option>
            </select></div>
          <div class="calc-field"><label>Sistema</label>
            <select id="fv-sistema" onchange="calcularFV()">
              <option value="ongrid">On-Grid (conectado a red)</option>
              <option value="offgrid">Off-Grid (autónomo)</option>
            </select></div>
        </div>
        <div class="calc-card">
