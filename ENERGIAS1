async function loadPresupuestos() {
  const { data } = await db.from('hes_presupuestos').select('*').order('created_at', { ascending: false });
  presupuestos = data || [];

  const termica = presupuestos.filter(p => !p.tipo_dim || p.tipo_dim === 'termica');
  const fv      = presupuestos.filter(p => p.tipo_dim === 'fv');

  const listaT = document.getElementById('dim-lista');
  const listaF = document.getElementById('fv-dim-lista');

  if (!termica.length) {
    listaT.innerHTML = '<div class="empty">Todavía no guardaste presupuestos térmicos</div>';
  } else {
    listaT.innerHTML = termica.map(p => `
      <div class="prov-card" style="margin-bottom:8px">
        <div class="prov-header">
          <div><div class="prov-name">${p.cliente}</div><div class="prov-web">${new Date(p.created_at).toLocaleDateString('es-AR')}</div></div>
          <button onclick="deleteDim(${p.id})" style="background:var(--rojo-light);color:var(--rojo);border:none;border-radius:6px;padding:4px 10px;font-size:12px;font-weight:600;cursor:pointer">Eliminar</button>
        </div>
        <div class="prov-rows">
          <div class="prov-row"><strong>Colectores:</strong> ${p.colectores} × 2 m²</div>
          <div class="prov-row"><strong>Área:</strong> ${p.area} m²</div>
          <div class="prov-row"><strong>Acumulador:</strong> ${p.acumulador} L</div>
          <div class="prov-row"><strong>Bomba:</strong> ${p.bomba} L/h</div>
          <div class="prov-row"><strong>Zona:</strong> ${p.zona}</div>
          <div class="prov-row"><strong>Tipo:</strong> ${p.tipo}</div>
        </div>
      </div>`).join('');
  }

  if (!fv.length) {
    listaF.innerHTML = '<div class="empty">Todavía no guardaste presupuestos fotovoltaicos</div>';
  } else {
    listaF.innerHTML = fv.map(p => {
      let extra = {};
      try { extra = JSON.parse(p.extra_json || '{}'); } catch(e) {}
      return `
      <div class="prov-card" style="margin-bottom:8px">
        <div class="prov-header">
          <div><div class="prov-name">${p.cliente}</div><div class="prov-web">${new Date(p.created_at).toLocaleDateString('es-AR')}</div></div>
          <button onclick="deleteDim(${p.id})" style="background:var(--rojo-light);color:var(--rojo);border:none;border-radius:6px;padding:4px 10px;font-size:12px;font-weight:600;cursor:pointer">Eliminar</button>
        </div>
        <div class="prov-rows">
          <div class="prov-row"><strong>kWp instalados:</strong> ${p.area} kWp</div>
          <div class="prov-row"><strong>Paneles:</strong> ${p.colectores} unidades</div>
          <div class="prov-row"><strong>Inversor:</strong> ${extra.inversor || '—'} kW</div>
          <div class="prov-row"><strong>Sistema:</strong> ${extra.sistema === 'offgrid' ? 'Off-Grid' : 'On-Grid'}</div>
          ${extra.bateria && extra.bateria !== '—' ? `<div class="prov-row"><strong>Batería:</strong> ${extra.bateria} kWh</div>` : ''}
          <div class="prov-row"><strong>Zona:</strong> ${p.zona}</div>
          <div class="prov-row"><strong>Panel:</strong> ${p.tipo}</div>
        </div>
      </div>`;
    }).join('');
  }
}

// ── CLIENTES ─────────────────────────────────────────────────────────────────
async function loadClientes() {
  const { data } = await db.from('hes_clientes').select('*').order('created_at', { ascending: false });
  clientes = data || [];
  renderClientes();
}

function renderClientes() {
  const list = document.getElementById('cliente-list');
  if (!clientes.length) { list.innerHTML = '<div class="empty">No hay clientes registrados todavía</div>'; return; }
  const statusMap = { consulta:['status-consulta','Consulta inicial'], cotizando:['status-cotizando','En cotización'], enviado:['status-enviado','Ppto. enviado'], cerrado:['status-cerrado','Cerrado ✅'], perdido:['status-perdido','Perdido ❌'] };
  list.innerHTML = clientes.map(c => {
    const [cls, lbl] = statusMap[c.estado] || ['status-consulta','Consulta'];
    return `<div class="cliente-card">
      <div>
        <div class="cliente-name">${c.nombre}</div>
        <div class="cliente-meta">${c.tipo} · ${c.contacto || '—'}</div>
        ${c.notas ? `<div class="cliente-meta" style="margin-top:3px">${c.notas}</div>` : ''}
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px">
        <span class="cliente-status-pill ${cls}">${lbl}</span>
        <button class="edit-btn" onclick="openClienteModal('${c.id}')">✎</button>
      </div>
    </div>`;
  }).join('');
}

function openClienteModal(id = null) {
  document.getElementById('cli-id').value = id || '';
  document.getElementById('cli-btn-delete').style.display = id ? 'block' : 'none';
  if (id) {
    const c = clientes.find(c => c.id == id);
    if (!c) return;
    document.getElementById('cli-nombre').value = c.nombre;
    document.getElementById('cli-contacto').value = c.contacto || '';
    document.getElementById('cli-tipo').value = c.tipo;
    document.getElementById('cli-estado').value = c.estado;
    document.getElementById('cli-notas').value = c.notas || '';
  } else {
    document.getElementById('cli-nombre').value = '';
    document.getElementById('cli-contacto').value = '';
    document.getElementById('cli-tipo').value = 'Solar Térmica — ACS';
    document.getElementById('cli-estado').value = 'consulta';
    document.getElementById('cli-notas').value = '';
  }
  const overlay = document.getElementById('modal-cliente');
  overlay.style.display = 'flex';
  overlay.classList.add('open');
  setTimeout(() => document.getElementById('cli-nombre').focus(), 50);
}

async function saveCliente() {
  const id = document.getElementById('cli-id').value;
  const payload = {
    nombre:   document.getElementById('cli-nombre').value.trim(),
    contacto: document.getElementById('cli-contacto').value.trim(),
    tipo:     document.getElementById('cli-tipo').value,
    estado:   document.getElementById('cli-estado').value,
    notas:    document.getElementById('cli-notas').value.trim(),
  };
  if (!payload.nombre) { toast('Ingresá el nombre'); return; }
  setSyncState('loading');
  let error;
  if (id) ({ error } = await db.from('hes_clientes').update(payload).eq('id', id));
  else    ({ error } = await db.from('hes_clientes').insert(payload));
  closeModal('modal-cliente');
  if (!error) { await loadClientes(); toast('Guardado ✓'); setSyncState('ok'); }
  else { setSyncState('error'); toast('Error al guardar'); }
}

async function deleteCliente() {
  const id = document.getElementById('cli-id').value;
  if (!id || !confirm('¿Eliminar este cliente?')) return;
  const { error } = await db.from('hes_clientes').delete().eq('id', id);
  closeModal('modal-cliente');
  if (!error) { await loadClientes(); toast('Eliminado'); }
}

// ── Cerrar modales clickando afuera ──────────────────────────────────────────
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', e => {
    if (e.target === overlay) {
      overlay.classList.remove('open');
      overlay.style.display = 'none';
    }
  });
});

