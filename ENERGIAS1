            <div class="result-box accent"><div class="result-val" id="r-acum">0</div><div class="result-label">litros acumulador</div><div class="result-note">con intercambiador</div></div>
            <div class="result-box accent"><div class="result-val" id="r-bomba">0</div><div class="result-label">L/h bomba</div><div class="result-note">circulación forzada</div></div>
