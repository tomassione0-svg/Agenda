<script>
// ── Supabase init ────────────────────────────────────────────────────────────
const { createClient } = supabase;
const db = createClient(SUPA_URL, SUPA_KEY);

// ── State ────────────────────────────────────────────────────────────────────
let tasks = [];
let clientes = [];
let presupuestos = [];

// ── UI helpers ────────────────────────────────────────────────────────────────
function showTab(name) {
  document.querySelectorAll('.tab').forEach((t, i) => {
    const names = ['agenda','proveedores','dimension','clientes'];
    t.classList.toggle('active', names[i] === name);
  });
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
}

function toast(msg, ms = 2200) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), ms);
}

function setSyncState(state) {
  const dot = document.getElementById('sync-dot');
  const lbl = document.getElementById('sync-label');
  dot.className = 'sync-dot ' + (state === 'ok' ? '' : state === 'error' ? 'offline' : 'loading');
  lbl.textContent = state === 'ok' ? 'Sincronizado' : state === 'error' ? 'Sin conexión' : 'Sincronizando...';
}

function closeModal(id) {
  const overlay = document.getElementById(id);
  overlay.classList.remove('open');
  overlay.style.display = 'none';
}

// ── TAREAS ────────────────────────────────────────────────────────────────────
async function loadTasks() {
  const { data, error } = await db.from('hes_tareas').select('*').order('created_at');
  if (error) { setSyncState('error'); return; }
  tasks = data || [];
  renderTasks();
  setSyncState('ok');
}

function renderTasks() {
  renderCol('termica');
  renderCol('fv');
  updateProgress();
}

function renderCol(col) {
  const container = document.getElementById('tasks-' + col);
  const colTasks = tasks.filter(t => t.columna === col);
  const sections = [...new Set(colTasks.map(t => t.seccion))];

  container.innerHTML = '';
  if (colTasks.length === 0) {
    container.innerHTML = '<div class="empty">No hay tareas aún</div>';
    return;
  }

  const sectionOrder = ['Esta semana', 'Semana que viene', 'Próximas semanas'];
  const sorted = sectionOrder.filter(s => sections.includes(s));

  sorted.forEach(sec => {
    const secTasks = colTasks.filter(t => t.seccion === sec);
    if (!secTasks.length) return;
    const secLabel = document.createElement('div');
    secLabel.style.cssText = 'font-size:11px;font-weight:600;color:var(--muted);margin:12px 0 5px;text-transform:uppercase;letter-spacing:.05em';
    secLabel.textContent = sec;
    container.appendChild(secLabel);
    secTasks.forEach(t => container.appendChild(renderTaskCard(t, col)));
  });
}

function renderTaskCard(t, col) {
  const card = document.createElement('div');
  card.className = 'task-card' + (t.estado === 'hecho' ? ' done' : '');
  card.dataset.id = t.id;

  const checkedClass = t.estado === 'hecho' ? (col === 'termica' ? 'checked-verde' : 'checked-azul') : '';

  const badgeMap = { hecho:'badge-hecho ✅ Hecho', curso:'badge-curso 🔄 En curso', pendiente:'badge-pend ⏳ Pendiente', urgente:'badge-urgente 🔥 Urgente' };
  const prioMap = { alta:'badge-alta 🔴 Alta', media:'badge-media 🟡 Media', baja:'badge-baja 🟢 Baja' };
  const [bCls, bTxt] = (badgeMap[t.estado] || 'badge-pend ⏳ Pendiente').split(' ').reduce((a,v,i) => i===0?[v,a[1]||'']:[a[0],a[1]+' '+v], ['','']);
  const [pCls, pTxt] = (prioMap[t.prioridad] || 'badge-baja 🟢 Baja').split(' ').reduce((a,v,i) => i===0?[v,a[1]||'']:[a[0],a[1]+' '+v], ['','']);

  card.innerHTML = `
    <div class="check-box ${checkedClass}" onclick="toggleTask(event,'${t.id}','${col}')">
      <span class="check-icon">✓</span>
    </div>
    <div class="task-body" onclick="openModal('${col}','${t.id}')">
      <div class="task-title">${t.tarea}</div>
      ${t.detalle ? `<div class="task-sub">${t.detalle}</div>` : ''}
      <div class="task-badges">
        <span class="badge ${bCls}">${bTxt.trim()}</span>
        <span class="badge ${pCls}">${pTxt.trim()}</span>
      </div>
    </div>`;
  return card;
}

async function toggleTask(e, id, col) {
  e.stopPropagation();
  const task = tasks.find(t => t.id == id);
  if (!task) return;
  const newEstado = task.estado === 'hecho' ? 'pendiente' : 'hecho';
  setSyncState('loading');
  const { error } = await db.from('hes_tareas').update({ estado: newEstado }).eq('id', id);
  if (!error) { task.estado = newEstado; renderTasks(); setSyncState('ok'); }
  else { setSyncState('error'); toast('Error al guardar'); }
}

function updateProgress() {
  ['termica','fv'].forEach(col => {
    const colTasks = tasks.filter(t => t.columna === col);
    const done = colTasks.filter(t => t.estado === 'hecho').length;
    const total = colTasks.length;
    const pct = total ? Math.round(done / total * 100) : 0;
    document.getElementById('bar-' + col).style.width = pct + '%';
    document.getElementById('pct-' + col).textContent = `${done} / ${total} · ${pct}%`;
  });
}

function openModal(col, id = null) {
  document.getElementById('modal-col').value = col;
  document.getElementById('modal-id').value = id || '';
  document.getElementById('modal-title').textContent = id ? 'Editar tarea' : 'Nueva tarea';
  document.getElementById('btn-delete').style.display = id ? 'block' : 'none';

  if (id) {
    const t = tasks.find(t => t.id == id);
    if (!t) return;
    document.getElementById('modal-tarea').value = t.tarea;
    document.getElementById('modal-detalle').value = t.detalle || '';
    document.getElementById('modal-estado').value = t.estado;
    document.getElementById('modal-prio').value = t.prioridad;
    document.getElementById('modal-seccion').value = t.seccion;
  } else {
    document.getElementById('modal-tarea').value = '';
    document.getElementById('modal-detalle').value = '';
    document.getElementById('modal-estado').value = 'pendiente';
    document.getElementById('modal-prio').value = 'media';
    document.getElementById('modal-seccion').value = 'Semana que viene';
  }
  const overlay = document.getElementById('modal-task');
  overlay.style.display = 'flex';
  overlay.classList.add('open');
  setTimeout(() => document.getElementById('modal-tarea').focus(), 50);
}

async function saveTask() {
  const id = document.getElementById('modal-id').value;
  const payload = {
    columna:  document.getElementById('modal-col').value,
    tarea:    document.getElementById('modal-tarea').value.trim(),
    detalle:  document.getElementById('modal-detalle').value.trim(),
    estado:   document.getElementById('modal-estado').value,
    prioridad:document.getElementById('modal-prio').value,
    seccion:  document.getElementById('modal-seccion').value,
  };
  if (!payload.tarea) { toast('Escribí el nombre de la tarea'); return; }
  setSyncState('loading');
  let error;
  if (id) {
    ({ error } = await db.from('hes_tareas').update(payload).eq('id', id));
  } else {
    ({ error } = await db.from('hes_tareas').insert(payload));
  }
  closeModal('modal-task');
  if (!error) { await loadTasks(); toast('Guardado ✓'); }
  else { setSyncState('error'); toast('Error al guardar'); }
}

async function deleteTask() {
  const id = document.getElementById('modal-id').value;
  if (!id) return;
  if (!confirm('¿Eliminar esta tarea?')) return;
  setSyncState('loading');
  const { error } = await db.from('hes_tareas').delete().eq('id', id);
  closeModal('modal-task');
  if (!error) { await loadTasks(); toast('Tarea eliminada'); }
  else { setSyncState('error'); }
}

// ── PROVEEDORES (dinámicos — Supabase) ───────────────────────────────────────
let proveedores = [];

const ESTADO_PROV = {
  sin_contacto:   { label: 'Sin contacto',          cls: 'badge-pend'    },
  contactado:     { label: '📞 Contactado',          cls: 'badge-curso'   },
  esperando:      { label: '⏳ Esperando respuesta', cls: 'badge-pend'    },
  en_negociacion: { label: '💬 En negociación',      cls: 'badge-urgente' },
  ppto_recibido:  { label: '📄 Ppto. recibido',      cls: 'badge-curso'   },
  acuerdo:        { label: '🤝 Acuerdo cerrado',     cls: 'badge-hecho'   },
  descartado:     { label: '❌ Descartado',           cls: 'badge-pend'    },
};

async function loadProveedores() {
  const { data, error } = await db.from('hes_proveedores').select('*').order('created_at');
  if (error) { setSyncState('error'); return; }
  proveedores = data || [];
  renderProveedores();
}

function renderProveedores() {
  const grid = document.getElementById('prov-grid');
  if (!proveedores.length) {
    grid.innerHTML = '<div class="empty">No hay proveedores cargados — agregá el primero con el botón de arriba</div>';
    return;
  }
  grid.innerHTML = proveedores.map(p => {
    const est = ESTADO_PROV[p.estado] || { label: p.estado, cls: 'badge-pend' };
    const prioMap = { alta:'prio-alta 🔴 Alta', media:'prio-media 🟡 Media', baja:'prio-baja 🟢 Baja' };
    const [prioCls, prioLbl] = (prioMap[p.prioridad] || 'prio-baja 🟢 Baja').split(' ').reduce((a,v,i) => i===0?[v,a[1]||'']:[a[0],a[1]+' '+v], ['','']);
    return `
    <div class="prov-card" style="cursor:pointer" onclick="openProvModal('${p.id}')">
      <div class="prov-header">
        <div>
          <div class="prov-name">${p.nombre}</div>
          <div class="prov-web">${p.web || ''}</div>
        </div>
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:5px">
          <span class="prio-pill ${prioCls}">${prioLbl.trim()}</span>
          <span class="badge ${est.cls}" style="font-size:11px">${est.label}</span>
        </div>
      </div>
      <div class="prov-rows">
        <div class="prov-row"><strong>Tipo:</strong> ${p.tipo || '—'}</div>
        <div class="prov-row"><strong>Categoría:</strong> ${p.categoria || '—'}</div>
        ${p.certs ? `<div class="prov-row" style="grid-column:1/-1"><strong>Cert:</strong> ${p.certs}</div>` : ''}
        ${p.productos ? `<div class="prov-row" style="grid-column:1/-1"><strong>Productos:</strong> ${p.productos}</div>` : ''}
        ${p.notas ? `<div class="prov-row" style="grid-column:1/-1;margin-top:4px;padding-top:6px;border-top:1px solid var(--gris-borde);color:var(--muted);font-style:italic">${p.notas}</div>` : ''}
      </div>
    </div>`;
  }).join('');
}

function openProvModal(id = null) {
  document.getElementById('prov-id').value = id || '';
  document.getElementById('prov-modal-title').textContent = id ? 'Editar proveedor' : 'Nuevo proveedor';
  document.getElementById('prov-btn-delete').style.display = id ? 'block' : 'none';
  if (id) {
    const p = proveedores.find(p => p.id == id);
    if (!p) return;
    document.getElementById('prov-nombre').value    = p.nombre || '';
    document.getElementById('prov-web').value       = p.web || '';
    document.getElementById('prov-tipo').value      = p.tipo || 'Importador directo';
    document.getElementById('prov-categoria').value = p.categoria || 'termica';
    document.getElementById('prov-prio').value      = p.prioridad || 'media';
    document.getElementById('prov-estado').value    = p.estado || 'sin_contacto';
    document.getElementById('prov-productos').value = p.productos || '';
    document.getElementById('prov-certs').value     = p.certs || '';
    document.getElementById('prov-notas').value     = p.notas || '';
  } else {
    document.getElementById('prov-nombre').value    = '';
    document.getElementById('prov-web').value       = '';
    document.getElementById('prov-tipo').value      = 'Importador directo';
    document.getElementById('prov-categoria').value = 'termica';
    document.getElementById('prov-prio').value      = 'media';
    document.getElementById('prov-estado').value    = 'sin_contacto';
    document.getElementById('prov-productos').value = '';
    document.getElementById('prov-certs').value     = '';
    document.getElementById('prov-notas').value     = '';
  }
  const overlay = document.getElementById('modal-prov');
  overlay.style.display = 'flex';
  overlay.classList.add('open');
  setTimeout(() => document.getElementById('prov-nombre').focus(), 50);
}

async function saveProv() {
  const id = document.getElementById('prov-id').value;
  const payload = {
    nombre:    document.getElementById('prov-nombre').value.trim(),
    web:       document.getElementById('prov-web').value.trim(),
    tipo:      document.getElementById('prov-tipo').value,
    categoria: document.getElementById('prov-categoria').value,
    prioridad: document.getElementById('prov-prio').value,
    estado:    document.getElementById('prov-estado').value,
    productos: document.getElementById('prov-productos').value.trim(),
    certs:     document.getElementById('prov-certs').value.trim(),
    notas:     document.getElementById('prov-notas').value.trim(),
  };
  if (!payload.nombre) { toast('Ingresá el nombre del proveedor'); return; }
  setSyncState('loading');
  let error;
  if (id) ({ error } = await db.from('hes_proveedores').update(payload).eq('id', id));
  else    ({ error } = await db.from('hes_proveedores').insert(payload));
  closeModal('modal-prov');
  if (!error) { await loadProveedores(); toast('Guardado ✓'); setSyncState('ok'); }
  else { setSyncState('error'); toast('Error al guardar'); }
}

async function deleteProv() {
  const id = document.getElementById('prov-id').value;
  if (!id || !confirm('¿Eliminar este proveedor?')) return;
  const { error } = await db.from('hes_proveedores').delete().eq('id', id);
  closeModal('modal-prov');
  if (!error) { await loadProveedores(); toast('Proveedor eliminado'); }
  else { setSyncState('error'); }
}

// ── DIMENSIONAMIENTO ──────────────────────────────────────────────────────────
function showDimTab(tab) {
  document.getElementById('dim-termica').style.display = tab === 'termica' ? 'block' : 'none';
  document.getElementById('dim-fv').style.display       = tab === 'fv'      ? 'block' : 'none';
  const tBtn = document.getElementById('dtab-termica');
  const fBtn = document.getElementById('dtab-fv');
  if (tab === 'termica') {
    tBtn.style.cssText = 'flex:1;padding:9px;border-radius:8px;border:1.5px solid var(--verde);background:var(--verde);color:#fff;font-size:13px;font-weight:600;cursor:pointer';
    fBtn.style.cssText = 'flex:1;padding:9px;border-radius:8px;border:1.5px solid var(--gris-borde);background:#fff;color:var(--muted);font-size:13px;font-weight:600;cursor:pointer';
  } else {
    fBtn.style.cssText = 'flex:1;padding:9px;border-radius:8px;border:1.5px solid var(--azul);background:var(--azul);color:#fff;font-size:13px;font-weight:600;cursor:pointer';
    tBtn.style.cssText = 'flex:1;padding:9px;border-radius:8px;border:1.5px solid var(--gris-borde);background:#fff;color:var(--muted);font-size:13px;font-weight:600;cursor:pointer';
  }
}

function calcular() {
  const personas  = parseFloat(document.getElementById('d-personas').value) || 0;
  const litros    = parseFloat(document.getElementById('d-litros').value) || 0;
  const tacum     = parseFloat(document.getElementById('d-tacum').value) || 55;
  const tred      = parseFloat(document.getElementById('d-tred').value) || 15;
  const hsp       = parseFloat(document.getElementById('d-zona').value) || 4.2;
  const eta       = parseFloat(document.getElementById('d-tipo').value) || 0.60;
  const cobertura = parseFloat(document.getElementById('d-cobertura').value) || 0.70;

  const totalLitros = personas * litros;
  const deltaT = tacum - tred;
  const energiaDia = (totalLitros * deltaT * 1.16) / 1000;
  const energiaAnualSolar = energiaDia * 365 * cobertura;
  const area = energiaAnualSolar / (hsp * eta * 365);
  const colectores = Math.ceil(area / 2);
  const acumulador = Math.round(area * 65);
  const bomba = Math.round(area * 35);

  document.getElementById('r-area').textContent = area.toFixed(1);
  document.getElementById('r-colectores').textContent = colectores;
  document.getElementById('r-acum').textContent = acumulador;
  document.getElementById('r-bomba').textContent = bomba;

  const tipoLabel = document.getElementById('d-tipo').options[document.getElementById('d-tipo').selectedIndex].text.split('—')[0].trim();
  document.getElementById('r-resumen').innerHTML = `
    <b>${colectores} colector${colectores > 1 ? 'es' : ''}</b> ${tipoLabel} de 2 m² c/u<br>
    Acumulador: <b>${acumulador} litros</b> con intercambiador de calor<br>
    Bomba: <b>${bomba} L/h</b> (circulación forzada)<br>
    Cobertura solar: <b>${Math.round(cobertura * 100)}%</b> de la demanda anual<br>
    Apoyo: calefón a gas o eléctrico en serie
  `;
}

function calcularFV() {
  const consumo   = parseFloat(document.getElementById('fv-consumo').value) || 0;
  const cobertura = parseFloat(document.getElementById('fv-cobertura').value) || 1.0;
  const hsp       = parseFloat(document.getElementById('fv-zona').value) || 4.2;
  const panelW    = parseFloat(document.getElementById('fv-panel').value) || 430;
  const pr        = parseFloat(document.getElementById('fv-pr').value) || 0.80;
  const sistema   = document.getElementById('fv-sistema').value;

  const consumoDia = (consumo * cobertura) / 30;
  const kwp = consumoDia / (hsp * pr);
  const paneles = Math.ceil((kwp * 1000) / panelW);
  const kwpReal = (paneles * panelW) / 1000;
  const inversor = +(kwpReal * 0.85).toFixed(1);

  let batLabel = '—', batNote = 'solo Off-Grid';
  if (sistema === 'offgrid') {
    const batKwh = Math.ceil(consumoDia * 2);
    batLabel = batKwh;
    batNote = 'autonomía 2 días';
  }

  document.getElementById('fv-r-kwp').textContent = kwpReal.toFixed(1);
  document.getElementById('fv-r-paneles').textContent = paneles;
  document.getElementById('fv-r-wpanel').textContent = `de ${panelW}W c/u`;
  document.getElementById('fv-r-inversor').textContent = inversor;
  document.getElementById('fv-r-bateria').textContent = batLabel;
  document.getElementById('fv-r-bat-note').textContent = batNote;

  const zonaLabel = document.getElementById('fv-zona').options[document.getElementById('fv-zona').selectedIndex].text.split('—')[0].trim();
  const sistLabel = sistema === 'ongrid' ? 'On-Grid (con inyección a red)' : 'Off-Grid (autónomo con baterías)';
  document.getElementById('fv-r-resumen').innerHTML = `
    <b>${paneles} paneles</b> de ${panelW}W = <b>${kwpReal.toFixed(1)} kWp</b> instalados<br>
    Inversor: <b>${inversor} kW</b> AC (factor DC/AC: ${(kwpReal/inversor).toFixed(2)})<br>
    Zona: <b>${zonaLabel}</b> · PR: <b>${pr}</b><br>
    Sistema: <b>${sistLabel}</b><br>
    ${sistema === 'offgrid' ? `Batería sugerida: <b>${batLabel} kWh</b> (LiFePO4)` : 'Medidor bidireccional requerido para excedente'}
  `;
}

