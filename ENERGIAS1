<div class="header">
  <div>
    <h1 style="font-size:18px;font-weight:600;letter-spacing:-0.3px;color:#fff">Proyecto de Energías Renovables</h1>
    <div class="header-sub">Solar Térmica + Fotovoltaico · De Energía</div>
  </div>
  <div class="sync-badge">
    <div class="sync-dot loading" id="sync-dot"></div>
    <span id="sync-label">Conectando...</span>
  </div>
</div>

<div class="tabs">
  <div class="tab active" onclick="showTab('agenda')">Checkpoints</div>
  <div class="tab" onclick="showTab('proveedores')">Proveedores</div>
  <div class="tab" onclick="showTab('dimension')">Dimensionamiento</div>
  <div class="tab" onclick="showTab('clientes')">Clientes</div>
</div>

<div class="main">

  <!-- ══ PÁGINA: AGENDA ══════════════════════════════════════════════════════ -->
  <div class="page active" id="page-agenda">

    <div class="progress-row">
      <div class="progress-card">
        <div class="progress-label"><span class="dot dot-verde"></span>Solar Térmica</div>
        <div class="bar-wrap"><div class="bar bar-verde" id="bar-termica" style="width:0%"></div></div>
        <div class="bar-pct" id="pct-termica">0 / 0</div>
      </div>
      <div class="progress-card">
        <div class="progress-label"><span class="dot dot-azul"></span>Fotovoltaico (con Adri)</div>
        <div class="bar-wrap"><div class="bar bar-azul" id="bar-fv" style="width:0%"></div></div>
        <div class="bar-pct" id="pct-fv">0 / 0</div>
      </div>
    </div>

    <!-- Solar Térmica -->
    <div class="section-label">☀ Solar Térmica</div>
    <div class="tasks" id="tasks-termica"></div>
    <button class="add-btn" onclick="openModal('termica')">＋ Agregar tarea</button>

    <div style="height:20px"></div>

    <!-- Fotovoltaico -->
    <div class="section-label">⚡ Fotovoltaico (con Adri)</div>
    <div class="tasks" id="tasks-fv"></div>
    <button class="add-btn" onclick="openModal('fv')">＋ Agregar tarea</button>

  </div>

  <!-- ══ PÁGINA: PROVEEDORES ════════════════════════════════════════════════ -->
  <div class="page" id="page-proveedores">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
      <div class="section-label" style="margin-top:4px;border:none;margin-bottom:0">CRM de Proveedores</div>
      <button class="btn btn-primary" style="font-size:13px;padding:7px 14px" onclick="openProvModal()">＋ Agregar proveedor</button>
    </div>
    <div class="prov-grid" id="prov-grid"></div>
  </div>

  <!-- ══ PÁGINA: DIMENSIONAMIENTO ══════════════════════════════════════════ -->
  <div class="page" id="page-dimension">

    <!-- Sub-tabs -->
    <div style="display:flex;gap:8px;margin:4px 0 16px">
      <button id="dtab-termica" onclick="showDimTab('termica')"
        style="flex:1;padding:9px;border-radius:8px;border:1.5px solid var(--verde);background:var(--verde);color:#fff;font-size:13px;font-weight:600;cursor:pointer">
        ☀ Solar Térmica
      </button>
      <button id="dtab-fv" onclick="showDimTab('fv')"
        style="flex:1;padding:9px;border-radius:8px;border:1.5px solid var(--gris-borde);background:#fff;color:var(--muted);font-size:13px;font-weight:600;cursor:pointer">
        ⚡ Fotovoltaico
      </button>
    </div>

    <!-- ── TÉRMICA ── -->
    <div id="dim-termica">
      <div class="calc-grid">
        <div class="calc-card">
          <h3>Datos del proyecto</h3>
          <div class="calc-field"><label>Cliente / Proyecto</label>
            <input type="text" id="d-cliente" placeholder="Nombre del cliente"></div>
          <div class="calc-field"><label>Cantidad de personas</label>
            <input type="number" id="d-personas" value="4" min="1" oninput="calcular()"></div>
          <div class="calc-field"><label>Litros/día por persona</label>
            <input type="number" id="d-litros" value="40" min="10" oninput="calcular()"></div>
          <div class="calc-field"><label>Temperatura acumulación (°C)</label>
            <input type="number" id="d-tacum" value="55" min="40" max="80" oninput="calcular()"></div>
          <div class="calc-field"><label>Temperatura agua de red (°C)</label>
            <input type="number" id="d-tred" value="15" min="5" max="30" oninput="calcular()"></div>
          <div class="calc-field"><label>Zona / Irradianza (kWh/m²/día)</label>
            <select id="d-zona" onchange="calcular()">
              <option value="4.2">Buenos Aires / AMBA — 4.2</option>
              <option value="4.5">Córdoba / Santa Fe — 4.5</option>
              <option value="5.2">Mendoza / San Juan — 5.2</option>
              <option value="5.8">NOA (Salta, Jujuy, La Rioja) — 5.8</option>
              <option value="3.5">Patagonia — 3.5</option>
              <option value="4.0">Entre Ríos / Rosario — 4.0</option>
            </select></div>
          <div class="calc-field"><label>Tipo de colector</label>
            <select id="d-tipo" onchange="calcular()">
              <option value="0.60">Plano — eficiencia 60%</option>
              <option value="0.70">Tubular al vacío — eficiencia 70%</option>
            </select></div>
          <div class="calc-field"><label>Cobertura solar deseada</label>
            <select id="d-cobertura" onchange="calcular()">
              <option value="0.60">60%</option>
              <option value="0.70" selected>70%</option>
              <option value="0.80">80%</option>
            </select></div>
        </div>
        <div class="calc-card">
          <h3>Resultados</h3>
          <div class="result-grid">
            <div class="result-box"><div class="result-val" id="r-area">0</div><div class="result-label">m² de colector</div><div class="result-note">área total necesaria</div></div>
